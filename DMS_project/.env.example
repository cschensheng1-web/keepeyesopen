# ==========================================
# DMS 疲劳驾驶辅助系统 — 环境变量配置
# 复制此文件为 .env 并填入真实值
# ==========================================

# --- DeepSeek 大模型配置 ---
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# --- MQTT 消息中间件 ---
MQTT_BROKER=broker.emqx.io
MQTT_PORT=1883
MQTT_TOPIC=dms/car/data

# --- 疲劳检测阈值（时间基准，单位：秒） ---
EAR_THRESHOLD=0.18
MAR_THRESHOLD=0.60
BLINK_MICRO_SLEEP_SEC=0.5
BLINK_DEEP_SLEEP_SEC=1.5
YAWN_DURATION_SEC=2.5

# --- AI 防爆冷却时间（秒） ---
COOLDOWN_SECONDS=4
